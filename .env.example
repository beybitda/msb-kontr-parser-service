# --- Oracle ---
DB_USER=user
DB_PASSWORD=password
DB_DSN=host:1521/service_name
DB_POOL_MIN=1
DB_POOL_MAX=5
DB_POOL_INCREMENT=1

# --- API security ---
# ключ, которым Informatica подписывает запрос на /parser/trigger
PARSER_API_KEY=change_me_shared_secret

# --- Парсинг (пока не используется, сервис отправляется без реализации парсеров) ---
REQUEST_TIMEOUT_SEC=15
REQUEST_DELAY_MIN_SEC=0.5
REQUEST_DELAY_MAX_SEC=2.0
MAX_ATTEMPTS=5

GOSZAKUP_BASE_URL=https://goszakup.gov.kz/ru/registry/contract
SAMRUK_BASE_URL=https://zakup.sk.kz/#/ext?tabs=contractCard&page=1

# --- Прочее ---
LOG_LEVEL=INFO
